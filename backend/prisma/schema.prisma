generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt         @id @default(autoincrement())
  userId        String         @unique
  name          String
  password      String
  profileImage  String?
  contact       String
  email         String         @unique
  role          UserRole       @default(USER)
  isActive      Boolean        @default(true)
  joinStatus    JoinStatus     @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  apartmentId   BigInt?
  residentId    BigInt?        @unique
  comments      Comment[]
  complaints    Complaint[]
  Notice        Notice[]
  notifications Notification[]
  polls         Poll[]
  apartment     Apartment?     @relation(fields: [apartmentId], references: [id], onDelete: NoAction)
  resident      Resident?      @relation(fields: [residentId], references: [id], onDelete: NoAction)
  votes         Vote[]

  @@index([apartmentId])
  @@index([role])
}

model Apartment {
  id                        BigInt     @id @default(autoincrement())
  apartmentName             String
  description               String?
  apartmentManagementNumber String
  apartmentAddress          String
  complexNumber             String?
  floorNumber               String?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  board                     Board[]
  residents                 Resident[]
  users                     User[]

  @@index([apartmentName])
}

model Board {
  id          BigInt      @id @default(autoincrement())
  type        BoardType
  apartmentId BigInt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  apartment   Apartment   @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  complaints  Complaint[]
  notices     Notice[]
  polls       Poll[]

  @@unique([apartmentId, type])
  @@index([apartmentId])
}

model Resident {
  id              BigInt          @id @default(autoincrement())
  name            String
  contact         String
  building        String
  unitNumber      String
  residenceStatus ResidenceStatus @default(RESIDENCE)
  isHouseholder   HouseholdType   @default(HOUSEMEMBER)
  isRegistered    Boolean         @default(false)
  approvalStatus  ApprovalStatus  @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  apartmentId     BigInt
  apartment       Apartment       @relation(fields: [apartmentId], references: [id])
  user            User?

  @@unique([apartmentId, building, unitNumber, contact])
  @@index([apartmentId, approvalStatus])
}

model Notice {
  id        BigInt         @id @default(autoincrement())
  category  NoticeCategory
  title     String
  content   String
  isPinned  Boolean        @default(false)
  viewCount Int            @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  boardId   BigInt
  userId    BigInt
  comments  Comment[]
  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  User      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, isPinned, createdAt(sort: Desc)])
  @@index([userId])
}

model Poll {
  id                 BigInt       @id @default(autoincrement())
  title              String
  content            String
  buildingPermission Int          @default(0)
  status             PollStatus   @default(PENDING)
  startDate          DateTime
  endDate            DateTime
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  boardId            BigInt
  userId             BigInt
  board              Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollOptions        PollOption[]

  @@index([boardId, status])
  @@index([userId])
}

model PollOption {
  id        BigInt   @id @default(autoincrement())
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pollId    BigInt
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     Vote[]

  @@index([pollId])
  @@index([pollId, order])
}

model Vote {
  id        BigInt     @id @default(autoincrement())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userId    BigInt
  optionId  BigInt
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])

  @@unique([userId, optionId])
}

model Complaint {
  id        BigInt          @id @default(autoincrement())
  title     String
  content   String
  isPrivate Boolean         @default(false)
  status    ComplaintStatus @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    BigInt
  boardId   BigInt
  comments  Comment[]
  board     Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, status])
  @@index([userId])
}

model Comment {
  id          BigInt     @id @default(autoincrement())
  content     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      BigInt
  noticeId    BigInt?
  complaintId BigInt?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  notice      Notice?    @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  User        User       @relation(fields: [userId], references: [id])

  @@index([noticeId])
  @@index([complaintId])
}

model Notification {
  id          BigInt           @id @default(autoincrement())
  content     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      BigInt
  referenceId BigInt?
  type        NotificationType
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PollStatus {
  PENDING
  IN_PROGRESS
  CLOSED
}

enum ApartmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum NoticeCategory {
  MAINTENANCE
  EMERGENCY
  COMMUNITY
  RESIDENT_VOTE
  RESIDENT_COUNCIL
  ETC
}

enum ResidenceStatus {
  RESIDENCE
  NO_RESIDENCE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HouseholdType {
  HOUSEHOLDER
  HOUSEMEMBER
}

enum BoardType {
  NOTICE
  COMPLAINT
  POLL
}

enum NotificationType {
  ADMIN_SIGNUP
  USER_SIGNUP
  NOTICE
  POLL
  COMPLAINT
}
